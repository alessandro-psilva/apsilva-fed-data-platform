# ============================================================================
# apsilva-fed-data-platform/.env.example
# ----------------------------------------------------------------------------
# Modelo de configuracao do frontend (nginx + assets/config.js) e Azurite.
# Copie para .env e ajuste conforme seu ambiente:
#
#   cp .env.example .env
# ============================================================================

# ============================================================================
# [BACKEND TARGET] - OBRIGATORIO
# ----------------------------------------------------------------------------
# BACKEND_HOST/BACKEND_PORT:
# - Referencia de host/porta da API usada por scripts e documentacao.
# - Em docker local, o service backend normalmente e apsilva-bed-data-platform-api.
BACKEND_HOST=apsilva-bed-data-platform-api
BACKEND_PORT=8000

# FRONTEND_API_BASE_URL:
# - URL consumida pelo browser (nao pelo container).
# - Deve ser acessivel do host/navegador.
# - Local recomendado: dominio .localhost mapeado para 127.0.0.1.
FRONTEND_API_BASE_URL=http://apsilva-bed-data-platform.localhost:8000

# Alternativa local valida (sem host customizado):
# FRONTEND_API_BASE_URL=http://localhost:8000

# ============================================================================
# [FRONTEND PORT] - OBRIGATORIO
# ----------------------------------------------------------------------------
# Porta HTTP publica do frontend no host.
FRONTEND_PORT=8080

# ============================================================================
# [AZURITE] - OPCIONAL (com defaults recomendados)
# ----------------------------------------------------------------------------
# Portas da emulacao local de Azure Storage.
AZURITE_BLOB_PORT=10000
AZURITE_QUEUE_PORT=10001
AZURITE_TABLE_PORT=10002

# Diretorio local para persistencia dos dados do Azurite.
# Pode ser relativo ao repo ou absoluto.
AZURITE_DATA_DIR=./azurite-data

# ============================================================================
# [DOCKER NETWORK] - OPCIONAL
# ----------------------------------------------------------------------------
# Nome da rede compartilhada entre repos do projeto.
PLATFORM_NET_NAME=apsilva-platform-network
